# ═══════════════════════════════════════════════════════════════
# AI Agent Configuration
# Copy this file to .env and fill in your values.
# All settings can also be set as environment variables directly.
# ═══════════════════════════════════════════════════════════════

# ── Provider Selection ─────────────────────────────────────────
# Supported: anthropic, openrouter, together, anyscale, deepseek, custom
AI_PROVIDER=anthropic

# ── API Key ────────────────────────────────────────────────────
# Generic key (used for any provider):
# AI_API_KEY=sk-xxx

# Or use provider-specific keys (auto-detected):
ANTHROPIC_API_KEY=sk-ant-xxx
# OPENROUTER_API_KEY=sk-or-xxx
# TOGETHER_API_KEY=xxx
# DEEPSEEK_API_KEY=sk-xxx

# ── Custom Endpoint ────────────────────────────────────────────
# Override the base URL (auto-set per provider, only set for custom endpoints):
# AI_BASE_URL=https://your-custom-api.example.com

# ── Model ──────────────────────────────────────────────────────
# Override the model (auto-set per provider, only set if you want a different one):
# AI_MODEL=claude-sonnet-4-6

# ── Thinking ───────────────────────────────────────────────────
# Set to "false" to disable extended thinking
# AI_THINKING=true

# ── Max Tokens ─────────────────────────────────────────────────
# AI_MAX_TOKENS=64000   # WARNING: 设置过大会显著增加费用（128K ≈ $2-4/call）

# ── Auto Routing ───────────────────────────────────────────────
# Automatically select ReAct vs general agent mode per query (default: true)
# AI_AUTO_ROUTE=true

# ── Router Model ───────────────────────────────────────────────
# Fast/cheap model used by the query router's LLM classifier.
# Defaults to the smallest model for each provider; only set to override.
# AI_ROUTER_MODEL=claude-haiku-4-5

# ── Skills Directory ───────────────────────────────────────────
# Override the skills directory path (default: ./skills)
# AI_SKILLS_DIR=./skills

# ── HuggingFace Mirror ───────────────────────────────────────────
# Override the HuggingFace endpoint for downloading embedding models.
# Useful in China where huggingface.co may be inaccessible.
# HF_ENDPOINT=https://hf-mirror.com
